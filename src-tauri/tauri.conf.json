{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WuwaMoMa",
  "version": "../package.json",
  "identifier": "com.WuwaMoMa.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WuwaMoMa",
        "width": 1000,
        "height": 1000
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}